# ── RPC ────────────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
RPC_WS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Jito ───────────────────────────────────────────────────────────────────────
JITO_BLOCK_ENGINE_URL=frankfurt.mainnet.block-engine.jito.wtf

# ── Wallet ─────────────────────────────────────────────────────────────────────
BOT_PRIVATE_KEY=         # base58-encoded keypair
BOT_WALLET_ADDR=         # base58-encoded public key

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# ── Trading ────────────────────────────────────────────────────────────────────
SIMULATION_MODE=true     # set false to submit real transactions
MIN_LIQUIDITY_SOL=5.0
MAX_BUY_SOL=0.1
TAKE_PROFIT_PCT=100
STOP_LOSS_PCT=30
SLIPPAGE_PCT=15
MAX_FRICTION_PCT=20.0
POSITION_MONITOR_INTERVAL=30    # seconds

# ── Solana Programs ────────────────────────────────────────────────────────────
RAYDIUM_AMM_PROGRAM=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8
PUMP_FUN_PROGRAM=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# ── API ────────────────────────────────────────────────────────────────────────
API_PORT=8080
